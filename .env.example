# NFT Bulk Minting CLI - Environment Configuration

# Your Ethereum wallet private key (DO NOT share or commit this file!)
# Must start with 0x
PRIVATE_KEY=0xyour_private_key_here

# RPC URL for the blockchain network
# Example: https://eth.llamarpc.com (public Ethereum RPC)
RPC_URL=https://eth.llamarpc.com

# Optional: Custom batch size (max NFTs per transaction)
# BATCH_SIZE=10

# Optional: Number of NFTs to mint per call
# MINT_AMOUNT=1
